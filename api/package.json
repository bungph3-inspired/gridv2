{
  "name": "gridv2-api",
  "version": "0.1.0",
  "private": true,
  "description": "GridV2 backend API (Hono + Drizzle)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "worker:oddspapi": "node dist/workers/oddspapi-poll.js",
    "worker:oddspapi:dev": "tsx watch src/workers/oddspapi-poll.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
