// ════════════════════════════════════════════════════════════════════════════
//  BetSimV2 — main.js
//  ────────────────────────────────────────────────────────────────────────────
//  This is the app's single ES module entry. Vite resolves it via the
//  <script type="module"> tag in index.html and bundles it with the CSS.
//
//  KEY DIFFERENCE FROM v1:
//  v1 had everything inlined in BetSim_Desktop.html — one giant <style> block
//  and one giant <script> block in the same file. v2 splits responsibilities:
//
//    index.html   →  pure markup
//    src/style.css →  tokens (@theme), components (@apply), utilities
//    src/main.js  →  this file — all behavior
//
//  The simulation logic (state, mock mode, normalize, render, mode switching,
//  bet builders for straight/parlay/teaser/ifbet, settle, settings) is ported
//  verbatim from v1. JS porting is NOT the v4 learning piece — it's plain
//  vanilla JS in both versions. Keep your eye on style.css for the migration
//  story.
// ════════════════════════════════════════════════════════════════════════════

// Vite-style CSS import. This triggers the @tailwindcss/vite plugin to
// compile @theme + utilities used in index.html and inject the result.
import './style.css';

// ════════════════════════════════════════════════════════
//  API KEY — leave empty. Set it via ⚙ Settings in-app
//  (it persists in localStorage as bs_key). Never commit
//  a real key here; this file is shared/distributed.
// ════════════════════════════════════════════════════════
const HARDCODED_KEY = '';

// ─── CONFIG — OddsPapi ───────────────────────────────
// Sport IDs: Basketball=11, Baseball=13, Hockey=15, AmFootball=14
// NBA tournament ID: 132 | MLB: fetched dynamically
// SPORT_CFG: one entry per *league*. Multiple leagues can share an OddsPapi
// sportId (e.g. NBA + NCAAB both = sportId 11). The `key` is unique per league
// and used internally; `sportId` is what we pass to OddsPapi URLs.
// `tournamentMatch` (regex) disambiguates which tournament to pick when several
// share the same sportId — e.g. NCAAB vs NBA in /tournaments?sportId=11.
const SPORT_CFG = [
  { key:'NBA',   label:'NBA',   sportId:11, tournamentId:132 },
  { key:'MLB',   label:'MLB',   sportId:13, tournamentId:null },
  { key:'NHL',   label:'NHL',   sportId:15, tournamentId:null },
  { key:'NFL',   label:'NFL',   sportId:14, tournamentId:null },
  { key:'NCAAB', label:'NCAAB', sportId:11, tournamentId:null, tournamentMatch:/NCAA|college/i },
  { key:'NCAAF', label:'NCAAF', sportId:14, tournamentId:null, tournamentMatch:/NCAA|college/i },
];
const AUTO_MS = 2 * 60 * 1000;

// ─── STATE ───────────────────────────────────────────
let apiKey     = localStorage.getItem('bs_key') || HARDCODED_KEY;
// Mock Mode default: ON when the fixture is available and the user hasn't
// explicitly opted out. New users see a working board immediately without
// needing to paste an API key. To opt out: uncheck "🎭 Mock Mode" in Settings,
// which writes 'bs_mock=0' to localStorage.
let mockMode   = !!window.MOCK_DATA && localStorage.getItem('bs_mock') !== '0';
let prefBook   = localStorage.getItem('bs_book') || 'draftkings';
let balance    = parseFloat(localStorage.getItem('bs_bal') || '1000');
let placedBets = JSON.parse(localStorage.getItem('bs_bets') || '[]');
let slip       = [];        // straight: {key,gameId,teamName,sport,matchup,type,line,vig,win}
let selCells   = {};
let parlayLegs = [];
let teaserLegs = [];           // {key,gameId,teamName,sport,matchup,type,origLine,shiftedLine}
let teaserVariant = null;      // null = on menu screen, 'PRIME6' = on board
let ifBetLegs  = [];           // {key,gameId,teamName,sport,matchup,type,line,vig,win,fireRule}
let wagerMode  = 'straight';   // 'straight' | 'parlay' | 'teaser' | 'ifbet'

// ─── TEASER CONFIG ───────────────────────────────────
// Each variant: shift in points (football, basketball), min/max legs, payout table {legs: amOdds}
// Sweetheart variants (3T 10-8, 4T 12-9) are fixed-leg with a single payout.
// Standard variants (6 / 6.5 / 7) scale 2–8 legs.
const TEASER_VARIANTS = [
  { key:'PRIME3T', label:'PRIME 3T 10-8',  ftbShift:10,   bbShift:8,   minLegs:3, maxLegs:3, enabled:true,
    payouts:{3:'+180'} },
  { key:'PRIME4T', label:'PRIME 4T 12-9',  ftbShift:12,   bbShift:9,   minLegs:4, maxLegs:4, enabled:true,
    payouts:{4:'+250'} },
  { key:'PRIME6',  label:'PRIME 6',        ftbShift:6,    bbShift:5.5, minLegs:2, maxLegs:8, enabled:true,
    payouts:{2:'-120',3:'+150',4:'+220',5:'+340',6:'+550',7:'+700',8:'+800'} },
  { key:'PRIME65', label:'PRIME 6.5',      ftbShift:6.5,  bbShift:6,   minLegs:2, maxLegs:8, enabled:true,
    payouts:{2:'-130',3:'+135',4:'+200',5:'+300',6:'+450',7:'+600',8:'+750'} },
  { key:'PRIME7',  label:'PRIME 7',        ftbShift:7,    bbShift:6.5, minLegs:2, maxLegs:8, enabled:true,
    payouts:{2:'-140',3:'+120',4:'+180',5:'+260',6:'+400',7:'+550',8:'+700'} },
];
const getVariant = k => TEASER_VARIANTS.find(v => v.key===k);

// ─── GAME META (for enriched info row) ───────────────
// Optional per-matchup meta. Keyed by "Away @ Home". Any/all fields optional.
// Renderer falls back to spare time+matchup format when no entry is found.
//   badge:     short tag (e.g., "Playoffs", "Reg Season"). Playoffs/Finals get teal-darker bg; others get orange.
//   seedAway/seedHome: integer seeds (rendered as "#N" before team names).
//   network:   broadcast network (e.g., "TNT", "Prime Video"). Rendered italicized after home team.
//   series:    series state (e.g., "OKC leads 2-1", "Tied 2-2"). Rendered as orange-tinted pill on the right.
//   maxWager:  numeric per-game wager cap. Rendered as "Max $1,000.00" on the right.
//   injury:    free-text injury note. Renders a sub-row beneath info row in red italic.
const BS_GAME_META = {
  'Los Angeles Lakers @ Oklahoma City Thunder': {
    badge:'Playoffs', seedAway:5, seedHome:1, network:'TNT',
    series:'OKC leads 2-1', maxWager:1000,
    injury:'LAL: L. James (questionable)'
  },
  'New York Knicks @ Philadelphia 76ers': {
    badge:'Playoffs', seedAway:3, seedHome:2, network:'ESPN',
    series:'Tied 2-2', maxWager:1000
  },
  'San Antonio Spurs @ Minnesota Timberwolves': {
    badge:'Reg Season', network:'NBA TV', maxWager:500
  },
};
function getGameMeta(g){
  return BS_GAME_META[`${g.away} @ ${g.home}`] || {};
}
// Map BetSim sport label → 'ftb' | 'bb' | null (not eligible for teaser)
const teaserSportType = sport => ({NBA:'bb', NCAAB:'bb', NFL:'ftb', NCAAF:'ftb'})[sport] || null;
// Apply teaser line shift. mkey: 'spread' | 'total'. side: 'home'/'away' implicit by sign.
function teaserShift(line, mkey, variant, sport) {
  const type = teaserSportType(sport);
  if (!type) return null;
  const shift = type==='ftb' ? variant.ftbShift : variant.bbShift;
  const n = parseFloat(line);
  if (isNaN(n)) return null;
  if (mkey==='spread') {
    // Spread shifts in bettor's favor: -7 → -1 (favorite), +3 → +9 (underdog)
    return n >= 0 ? `+${(n+shift).toFixed(1).replace(/\.0$/,'')}` : `${(n+shift).toFixed(1).replace(/\.0$/,'')}`;
  }
  // Total: over moves down, under moves up. Convention: line stored as just number; o/u in display
  // We'll preserve the raw shifted value; display layer marks o/u.
  return (n - shift).toFixed(1).replace(/\.0$/,''); // assume "over" leg perspective; under handled at render
}
const teaserPayout = (variant, n) => variant.payouts && variant.payouts[n] ? variant.payouts[n] : null;
let activeLeague = 'NBA – Playoffs';
let gamesCache = {};
let prevOdds   = {};
let qUsed = parseInt(localStorage.getItem('bs_qu')||'0');
let qRem  = parseInt(localStorage.getItem('bs_qr')||'500');
let autoTimer=null, cdownTimer=null, cdownSec=0;
let isLoading=false;

// ─── MATH ────────────────────────────────────────────
const toDec = am => { const n=parseFloat(String(am).replace('+','')); if(isNaN(n)) return 1; return n>0?n/100+1:100/Math.abs(n)+1; };
const calcRisk = (win,am) => { const d=toDec(am); return d<=1?0:win/(d-1); };
const calcWin  = (risk,am) => (toDec(am)-1)*risk;
const parlayDec = legs => legs.reduce((a,l)=>a*toDec(l.vig||l.line),1);
const decToAm = dec => dec>=2?'+'+Math.round((dec-1)*100):String(Math.round(-100/(dec-1)));
const fmtAm = n => n>0?'+'+n:String(n);
// ensureSign: normalize American odds (string or number) to always carry a +/- sign.
// OddsPapi's priceAmerican may arrive as "320" without a leading + on positives.
const ensureSign = v => {
  if(v==null||v==='') return '';
  const s=String(v).trim().replace(/^\+/,'');
  const n=parseFloat(s);
  if(isNaN(n)) return v;
  return n>0?'+'+n:String(n);
};
const fmtUSD = n => '$'+Math.abs(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});

// ─── HTML ESCAPE (for any API-sourced string going into innerHTML) ───
const _escDiv = document.createElement('div');
const escapeHtml = s => { _escDiv.textContent = s==null ? '' : String(s); return _escDiv.innerHTML; };

// ─── ODDSPAPI INTEGRATION ────────────────────────────
// Market resolution: ML is always marketId 111; spreads/totals use handicap-specific IDs
// looked up via /markets?sportId=N — see fetchMarketMeta + normalizeGames below.
const BASE = 'https://api.oddspapi.io/v4';
let participantCache = {}; // id → name

// Mock-mode router: resolves API paths against the captured fixture in mock_data.js.
// Returns undefined for endpoints not covered (caller falls through to live fetch).
function mockResolve(path) {
  const M = window.MOCK_DATA;
  if (!M) return undefined;
  if (path.startsWith('/tournaments?')) {
    const sid = parseInt(new URLSearchParams(path.split('?')[1]).get('sportId'));
    return sid===M.sportId ? [{tournamentId:M.tournamentId, tournamentName:'NBA', upcomingFixtures:1, liveFixtures:1, categorySlug:'usa', categoryName:'USA'}] : [];
  }
  if (path.startsWith('/markets?')) {
    const sid = parseInt(new URLSearchParams(path.split('?')[1]).get('sportId'));
    return sid===M.sportId ? M.markets : [];
  }
  if (path.startsWith('/odds-by-tournaments?')) {
    const tids = (new URLSearchParams(path.split('?')[1]).get('tournamentIds')||'').split(',').map(s=>parseInt(s));
    return tids.includes(M.tournamentId) ? M.odds : [];
  }
  if (path.startsWith('/participants?')) return M.participants;
  return undefined;
}

async function apiFetch(path) {
  if (mockMode && window.MOCK_DATA) {
    const r = mockResolve(path);
    if (r !== undefined) return Promise.resolve(r);
  }
  if (!apiKey||apiKey==='') { showBoardMsg('key'); return null; }
  const sep = path.includes('?')?'&':'?';
  const res = await fetch(`${BASE}${path}${sep}apiKey=${apiKey}`);
  if (!res.ok) { const e=await res.json().catch(()=>({})); throw new Error(e.error?.message||`HTTP ${res.status}`); }
  return res.json();
}

async function resolveParticipants(ids, sportId) {
  const missing = ids.filter(id=>!participantCache[id]);
  if (!missing.length) return;
  // OddsPapi /participants requires sportId (numeric)
  const data = await apiFetch(`/participants?participantIds=${missing.join(',')}&sportId=${sportId}`);
  // Handle both shapes: array of {participantId, participantName} OR object {id: name}
  if (Array.isArray(data)) {
    data.forEach(p=>{ participantCache[p.participantId]=p.participantName||p.shortName||String(p.participantId); });
  } else if (data && typeof data==='object') {
    Object.keys(data).forEach(id=>{ participantCache[id] = (typeof data[id]==='string') ? data[id] : (data[id]?.participantName||data[id]?.shortName||String(id)); });
  }
}

// Market metadata cache: sportId → { marketId → metadata } from /markets?sportId=N.
// The odds response gives priceAmerican by marketId+outcomeId, but the line/handicap
// value lives in this metadata catalog (keyed by marketId). We need both to render.
let marketMetaCache = {};

async function fetchMarketMeta(sportId) {
  // Cache by sportId (not league key) — multiple leagues share the same catalog
  // (e.g. NBA and NCAAB both consume sportId 11's markets metadata).
  if (marketMetaCache[sportId]) return;
  const data = await apiFetch(`/markets?sportId=${sportId}`);
  if (!Array.isArray(data)) return;
  const byId = {};
  data.forEach(m => { byId[m.marketId] = m; });
  marketMetaCache[sportId] = byId;
}

async function fetchOdds(sportKey) {
  if (!mockMode && (!apiKey||apiKey==='YOUR_API_KEY_HERE')) { showBoardMsg('key'); return null; }
  const cfg = SPORT_CFG.find(s=>s.key===sportKey);
  if (!cfg) return null;
  const sportId = cfg.sportId;

  // Get tournament ID if we don't have it yet
  if (!cfg.tournamentId) {
    const tours = await apiFetch(`/tournaments?sportId=${sportId}`);
    if (Array.isArray(tours)) {
      // Active tournaments only
      const candidates = tours.filter(t=>t.upcomingFixtures>0||t.liveFixtures>0);
      // If cfg.tournamentMatch is set (e.g. NCAAB, NCAAF), require a match — no
      // fallback. Otherwise NCAAB would silently pick the NBA tournament for
      // sportId 11. Without tournamentMatch we use the USA/major-league heuristic.
      const active = cfg.tournamentMatch
        ? candidates.find(t => cfg.tournamentMatch.test(t.tournamentName||''))
        : candidates.find(t=>(t.categorySlug==='usa'||t.categoryName==='USA'||t.tournamentName?.includes('MLB')||t.tournamentName?.includes('NBA')||t.tournamentName?.includes('NHL')||t.tournamentName?.includes('NFL')));
      if (active) cfg.tournamentId = active.tournamentId;
    }
    if (!cfg.tournamentId) { showBoardMsg('err','No active tournaments found for '+cfg.label); return null; }
  }

  // Markets metadata is needed to resolve handicap/total values (not in odds response)
  await fetchMarketMeta(sportId);

  const data = await apiFetch(`/odds-by-tournaments?bookmaker=${prefBook}&tournamentIds=${cfg.tournamentId}&oddsFormat=american`);
  if (!Array.isArray(data)) return null;

  // Resolve all participant names
  const pids = [...new Set(data.flatMap(g=>[g.participant1Id,g.participant2Id]))];
  await resolveParticipants(pids, sportId);

  // No quota headers from OddsPapi — just show connected
  updateQuota();
  return data;
}

// Format a points/handicap value: add + for positive, swap .5 → ½
const fmtLine = pt => {
  if (pt==null||pt==='') return '';
  const n = Number(pt);
  if (isNaN(n)) return String(pt);
  const abs = Math.abs(n);
  const whole = Math.floor(abs);
  const isHalf = (abs - whole) === 0.5;
  const body = isHalf ? (whole>0 ? whole+'½' : '½') : String(abs);
  return n<0 ? '-'+body : (n>0 ? '+'+body : '0');
};

// Like fmtLine but no leading sign — for totals (always positive line value).
const fmtTotalLine = pt => {
  if (pt==null||pt==='') return '';
  const n = Math.abs(Number(pt));
  if (isNaN(n)) return String(pt);
  const whole = Math.floor(n);
  const isHalf = (n - whole) === 0.5;
  return isHalf ? (whole>0 ? whole+'½' : '½') : String(n);
};

function normalizeGames(data, label, sportKey) {
  if (!Array.isArray(data)) return [];
  // Look up the league cfg to find its sportId — meta cache is keyed by sportId
  // (shared across leagues with the same OddsPapi sport: NBA + NCAAB both = 11)
  const cfg = SPORT_CFG.find(s => s.key === sportKey);
  const meta = (cfg && marketMetaCache[cfg.sportId]) || {};

  return data.map(ev => {
    const bm = ev.bookmakerOdds?.[prefBook];
    if (!bm || !bm.bookmakerIsActive) return null;
    const mkts = bm.markets || {};

    const p1name = participantCache[ev.participant1Id] || `Team ${ev.participant1Id}`;
    const p2name = participantCache[ev.participant2Id] || `Team ${ev.participant2Id}`;

    // Find main markets by joining odds keys with metadata catalog.
    // Filter: period='result' (full game), marketLength=2 (binary outcome), not playerProp.
    // Spreads/totals/team-totals: many handicap variants exist; pick the one whose first
    // outcome's first player has mainLine===true (the "main" line books promote on the board).
    //
    // Team-total convention in OddsPapi:
    //   teamtotals-team1 → participant1 (= HOME team) own total
    //   teamtotals-team2 → participant2 (= AWAY team) own total
    //   Each market's outcome[0] is OVER, outcome[1] is UNDER for that team's total.
    let mlMkt=null, spMkt=null, spMeta=null, totMkt=null, totMeta=null;
    let tt1Mkt=null, tt1Meta=null, tt2Mkt=null, tt2Meta=null;
    // Team-total fallback: DraftKings doesn't always set mainLine=true on team-totals
    // (reliable for spreads/totals but spotty for teamtotals in observed fixtures).
    // Track a fallback per side so we surface *something* when no flagged main exists.
    let tt1Fb=null, tt2Fb=null;
    for (const id in mkts) {
      const md = meta[id];
      if (!md || md.period !== 'result' || md.playerProp || md.marketLength !== 2) continue;
      const m = mkts[id];
      const o1id = md.outcomes[0].outcomeId;
      const p1 = m.outcomes?.[o1id]?.players?.[0];
      if (!p1) continue;
      if (md.marketType === 'moneyline' && !mlMkt) {
        mlMkt = {market:m, meta:md};
      } else if (md.marketType === 'spreads' && p1.mainLine === true && !spMkt) {
        spMkt = {market:m, meta:md}; spMeta = md;
      } else if (md.marketType === 'totals' && p1.mainLine === true && !totMkt) {
        totMkt = {market:m, meta:md}; totMeta = md;
      } else if (md.marketType === 'teamtotals-team1') {
        if (p1.mainLine === true && !tt1Mkt) { tt1Mkt = {market:m, meta:md}; tt1Meta = md; }
        else if (!tt1Fb) { tt1Fb = {market:m, meta:md}; }
      } else if (md.marketType === 'teamtotals-team2') {
        if (p1.mainLine === true && !tt2Mkt) { tt2Mkt = {market:m, meta:md}; tt2Meta = md; }
        else if (!tt2Fb) { tt2Fb = {market:m, meta:md}; }
      }
    }
    // Apply team-total fallbacks when no flagged-main was found
    if (!tt1Mkt && tt1Fb) { tt1Mkt = tt1Fb; tt1Meta = tt1Fb.meta; }
    if (!tt2Mkt && tt2Fb) { tt2Mkt = tt2Fb; tt2Meta = tt2Fb.meta; }

    // Helper: get priceAmerican from a {market,meta} pair by outcome index (0 or 1)
    const getVig = (pair, idx) => {
      if (!pair) return '';
      const oid = pair.meta.outcomes[idx].outcomeId;
      const p = pair.market.outcomes?.[oid]?.players?.[0];
      return (p?.active && p.priceAmerican) ? p.priceAmerican : '';
    };

    // Moneyline: outcome[0]=p1 (home), outcome[1]=p2 (away)
    const mlP1 = getVig(mlMkt, 0);
    const mlP2 = getVig(mlMkt, 1);

    // Spread: handicap is the home (p1) line; away (p2) line is the negation
    const spP1Line = spMeta ? fmtLine(spMeta.handicap) : '';
    const spP2Line = spMeta ? fmtLine(-spMeta.handicap) : '';
    const spP1Vig  = getVig(spMkt, 0);
    const spP2Vig  = getVig(spMkt, 1);

    // Total: handicap is the o/u line; outcome[0]=Over, outcome[1]=Under
    const totLine    = totMeta ? fmtTotalLine(totMeta.handicap) : '';
    const totOverVig  = getVig(totMkt, 0);
    const totUnderVig = getVig(totMkt, 1);

    // Team Totals: each team has its own total. We surface the OVER side of each
    // team's own total on that team's row (e.g. away row shows "Over away's TT",
    // home row shows "Over home's TT"). The UNDER variants are accessible per
    // OddsPapi's full market list but we don't have UI surface for them in this
    // one-cell-per-team layout — out of scope for this pass.
    const tt1Line = tt1Meta ? fmtTotalLine(tt1Meta.handicap) : '';   // home team's TT
    const tt1Vig  = getVig(tt1Mkt, 0);                               // over (p1's row)
    const tt2Line = tt2Meta ? fmtTotalLine(tt2Meta.handicap) : '';   // away team's TT
    const tt2Vig  = getVig(tt2Mkt, 0);                               // over (p2's row)

    const gt = new Date(ev.startTime);
    const isLive = ev.statusId===1 || gt<new Date();

    // p1=home, p2=away in OddsPapi convention
    return {
      id: ev.fixtureId,
      sport: label, isLive,
      date: gt.toLocaleDateString('en-US',{weekday:'long',month:'short',day:'numeric'}),
      time: gt.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',timeZoneName:'short'}),
      home: p1name, away: p2name,
      teams: [
        // Away team (p2)
        { name:p2name, abbr:p2name.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase(),
          spread: spP2Line, spVig: ensureSign(spP2Vig),
          ml: ensureSign(mlP2),
          total: totLine?('o'+totLine):'', totVig: ensureSign(totOverVig),
          tt: tt2Line?('o'+tt2Line):'', ttVig: ensureSign(tt2Vig),
        },
        // Home team (p1)
        { name:p1name, abbr:p1name.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase(),
          spread: spP1Line, spVig: ensureSign(spP1Vig),
          ml: ensureSign(mlP1),
          total: totLine?('u'+totLine):'', totVig: ensureSign(totUnderVig),
          tt: tt1Line?('o'+tt1Line):'', ttVig: ensureSign(tt1Vig),
        },
      ],
    };
  }).filter(Boolean);
}

async function fetchAndRender(sportKey,loader=true) {
  if(isLoading) return; isLoading=true; setSpinner(true);
  if(loader&&!gamesCache[sportKey]) showBoardMsg('load');
  try {
    const raw=await fetchOdds(sportKey);
    if(!raw){isLoading=false;setSpinner(false);return;}
    const label=SPORT_CFG.find(s=>s.key===sportKey)?.label||sportKey;
    const games=normalizeGames(raw,label,sportKey);
    const moved=detectMoved(games);
    gamesCache[sportKey]=games;
    // Re-render board if this sport is currently active
    const sc=SPORT_CFG.find(s=>s.key===sportKey);
    const activeSportKey=getActiveSportKey();
    if(sc&&sportKey===activeSportKey) renderBoard(moved);
    document.getElementById('lupd').textContent='Updated '+new Date().toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
    setOnline(true);
    if(moved.size) showToast(`📈 ${moved.size} line${moved.size>1?'s':''} moved`);
  } catch(e) {
    setOnline(false);
    if(!Object.keys(gamesCache).length) showBoardMsg('err',e.message);
    else showToast('⚠ Refresh failed');
  }
  isLoading=false; setSpinner(false);
}

function detectMoved(games) {
  // Returns a Map of key → 'up' | 'dn'. Direction is determined by comparing the
  // current numeric line value against the previously stored value, NOT by the
  // sign of the line itself (a -160 ML moving to -150 is an "up" move for backers).
  const moved=new Map();
  games.forEach(g=>g.teams.forEach(t=>{
    ['spread','ml','total','tt'].forEach(mk=>{
      const line=mk==='spread'?t.spread:mk==='ml'?t.ml:mk==='total'?t.total:t.tt;
      const vig=mk==='spread'?t.spVig:mk==='ml'?'':mk==='total'?t.totVig:t.ttVig;
      const key=`${g.id}_${t.name}_${mk}`;
      const prev=prevOdds[key],curr=line+vig;
      if(prev&&prev!==curr&&line) {
        const prevLineMatch=String(prev).match(/-?\d+(\.\d+)?/);
        const prevLineNum=prevLineMatch?parseFloat(prevLineMatch[0]):NaN;
        const currLineNum=parseFloat(line);
        if(!isNaN(prevLineNum)&&!isNaN(currLineNum)&&prevLineNum!==currLineNum) {
          moved.set(key, currLineNum > prevLineNum ? 'up' : 'dn');
        }
      }
      if(line) prevOdds[key]=curr;
    });
  }));
  return moved;
}

async function manualRefresh(){await fetchAndRender(getActiveSportKey(),false);resetAuto();}

function getActiveSportKey(){
  // Map the active sidebar league name to a SPORT_CFG key. NCAA* checked first
  // (more specific) so "NCAAB" doesn't accidentally match the "NBA" prefix.
  if(activeLeague.startsWith('NCAAB')) return 'NCAAB';
  if(activeLeague.startsWith('NCAAF')) return 'NCAAF';
  if(activeLeague.startsWith('NBA')) return 'NBA';
  if(activeLeague.startsWith('MLB')) return 'MLB';
  if(activeLeague.startsWith('NHL')) return 'NHL';
  if(activeLeague.startsWith('NFL')) return 'NFL';
  return SPORT_CFG[0].key;
}

function startAuto(){
  clearInterval(autoTimer);clearInterval(cdownTimer);
  cdownSec=AUTO_MS/1000;
  cdownTimer=setInterval(()=>{
    cdownSec--;
    const m=Math.floor(cdownSec/60),s=String(cdownSec%60).padStart(2,'0');
    document.getElementById('auto-timer').textContent=` | Auto: ${m}:${s}`;
    if(cdownSec<=0) cdownSec=AUTO_MS/1000;
  },1000);
  autoTimer=setInterval(()=>{ fetchAndRender('NBA',false); setTimeout(()=>fetchAndRender('MLB',false),1500); },AUTO_MS);
}
function resetAuto(){clearInterval(autoTimer);clearInterval(cdownTimer);startAuto();}

// ─── STATUS ──────────────────────────────────────────
function setOnline(ok){
  const d=document.getElementById('ldot'),t=document.getElementById('api-status');
  d.className=ok?'ldot live':'ldot off';
  t.textContent = mockMode ? '🎭 Mock Mode' : (ok?'Live':'Offline');
}
function setSpinner(on){document.getElementById('upd-btn').classList.toggle('spinning',on);}
function updateQuota(){
  const total=qUsed+qRem,pct=total>0?Math.round(qUsed/total*100):0;
  const cls=qRem<50?'bad':qRem<150?'warn':'ok';
  document.getElementById('qtxt').innerHTML=` | Quota: <span class="${cls}">${qRem}</span> left`;
  const bar=document.getElementById('qbar');
  bar.style.width=pct+'%';bar.className='qbar-fill'+(qRem<50?' bad':qRem<150?' warn':'');
  const eu=document.getElementById('q-used');if(eu)eu.textContent=qUsed+' used';
  const er=document.getElementById('q-rem');if(er)er.textContent=qRem+' remaining';
}

// ─── SIDEBAR ─────────────────────────────────────────
const LEAGUES_LIST=[
  {sport:'NBA',name:'NBA – Playoffs'},{sport:'NBA',name:'NBA – Series'},
  {sport:'NBA',name:'NBA 1st Half'},{sport:'NBA',name:'NBA Game & Player Props'},
  {sport:'MLB',name:'MLB'},{sport:'MLB',name:'MLB 1st 5 Innings'},
  {sport:'MLB',name:'MLB – Props'},{sport:'MLB',name:'MLB – Alternate Lines'},
  {sport:'NHL',name:'NHL – Playoffs'},{sport:'NHL',name:'NHL – Stanley Cup'},
  {sport:'NFL',name:'NFL – Preseason'},{sport:'NFL',name:'NFL – Regular Season'},
  {sport:'NCAAB',name:'NCAAB – Regular Season'},{sport:'NCAAB',name:'NCAAB – March Madness'},
  {sport:'NCAAF',name:'NCAAF – Regular Season'},{sport:'NCAAF',name:'NCAAF – Bowl Games'},
];

function renderSidebar(){
  const sports=[...new Set(LEAGUES_LIST.map(l=>l.sport))];
  const c=document.getElementById('sidebar-leagues');c.innerHTML='';
  sports.forEach(sport=>{
    const leagues=LEAGUES_LIST.filter(l=>l.sport===sport);
    const grp=document.createElement('div');grp.className='lg-group';
    const hdr=document.createElement('div');hdr.className='lg-hdr';
    hdr.dataset.sport = sport;  // used by filterSport to show/hide groups
    hdr.innerHTML=`${sport} <span class="chev">▾</span>`;
    hdr.onclick=()=>{hdr.classList.toggle('collapsed');items.classList.toggle('hidden');};
    const items=document.createElement('div');items.className='lg-items';
    leagues.forEach(l=>{
      const item=document.createElement('div');
      item.className='lg-item'+(l.name===activeLeague?' active':'');
      item.innerHTML=`<input type="checkbox" ${l.name===activeLeague?'checked':''}> ${l.name}`;
      item.onclick=()=>{
        activeLeague=l.name;
        document.getElementById('board-title').textContent=l.name;
        document.querySelectorAll('.lg-item').forEach(i=>i.classList.remove('active'));
        item.classList.add('active');
        // fetch sport for this league
        const sportKey=getActiveSportKey();
        const sc=SPORT_CFG.find(s=>s.key===sportKey);
        if(sc&&gamesCache[sc.key]) renderBoard();
        else if(sc) fetchAndRender(sc.key,true);
      };
      items.appendChild(item);
    });
    grp.appendChild(hdr);grp.appendChild(items);c.appendChild(grp);
  });
}

// ─── BOARD ───────────────────────────────────────────
function showBoardMsg(type,msg=''){
  const b=document.getElementById('board');
  if(type==='load') b.innerHTML=`<div class="ldstate"><div class="spinner"></div><div>Fetching live odds…</div></div>`;
  else if(type==='err') b.innerHTML=`<div class="errstate"><div style="font-size:36px">📡</div><div class="errmsg">Could not load odds</div><div class="errhint">${msg||'Check your API key in ⚙ Settings.'}</div><button class="retrybtn" onclick="manualRefresh()">Retry</button></div>`;
  else if(type==='key') b.innerHTML=`<div class="errstate"><div style="font-size:36px">🔑</div><div class="errmsg">API Key Required</div><div class="errhint">Click ⚙ Settings in the header to add your free key from the-odds-api.com</div></div>`;
}

function renderBoard(moved=new Map()){
  const b=document.getElementById('board');b.innerHTML='';
  // get games for the active sport
  const activeSportKey=getActiveSportKey();
  const sc=SPORT_CFG.find(s=>s.key===activeSportKey);
  if(!sc){b.innerHTML='<div class="ldstate" style="color:var(--text-xs)">Select a league from the sidebar.</div>';return;}
  const games=gamesCache[sc.key]||[];
  if(!games.length){b.innerHTML='<div class="ldstate" style="color:var(--text-xs)">No upcoming games for this league.</div>';return;}
  let lastDate='';
  games.forEach(g=>{
    if(g.date!==lastDate){
      lastDate=g.date;
      const d=document.createElement('div');d.className='dsep';d.textContent=g.date;b.appendChild(d);
    }
    b.appendChild(buildGameBlock(g,moved));
  });
}

function buildGameBlock(game,moved=new Map()){
  const block=document.createElement('div');block.className='gblock';
  // game info row (with optional enriched meta)
  const m=getGameMeta(game);
  const info=document.createElement('div');info.className='ginfo';
  const timeHtml=`<span class="gtime-lbl${game.isLive?' live':''}">${game.isLive?'● LIVE':escapeHtml(game.time)}</span>`;
  const isPlayoffs=m.badge && /playoff|finals|conference|championship/i.test(m.badge);
  const badgeHtml=m.badge?`<span class="gbadge${isPlayoffs?'':' alt'}">${escapeHtml(m.badge)}</span>`:'';
  const awaySeed=m.seedAway?`<span class="gseed">#${m.seedAway}</span>`:'';
  const homeSeed=m.seedHome?`<span class="gseed">#${m.seedHome}</span>`:'';
  const netHtml=m.network?`<span class="gnet">(${escapeHtml(m.network)})</span>`:'';
  const descHtml=`<span class="gdesc">${awaySeed}${escapeHtml(game.away)}<span class="vs">vs</span>${homeSeed}${escapeHtml(game.home)}${netHtml}</span>`;
  const seriesHtml=m.series?`<span class="gseries">${escapeHtml(m.series)}</span>`:'';
  const maxWHtml=m.maxWager?`<span class="gmaxw">Max ${fmtUSD(m.maxWager)}</span>`:'';
  const metaHtml=(seriesHtml||maxWHtml)?`<span class="ginfo-meta">${seriesHtml}${maxWHtml}</span>`:'';
  info.innerHTML=`${timeHtml}${badgeHtml}${descHtml}${metaHtml}`;
  block.appendChild(info);
  // injury sub-row (optional)
  if(m.injury){
    const inj=document.createElement('div');inj.className='ginjury';
    inj.textContent=m.injury;
    block.appendChild(inj);
  }
  // team rows
  game.teams.forEach(team=>{
    const row=document.createElement('div');row.className='trow-g';
    const logo=`<div class="tlogo">${escapeHtml(team.abbr)}</div>`;
    row.innerHTML=`<div class="tname-g">${logo}${escapeHtml(team.name)}</div>`;
    if(wagerMode==='teaser' && teaserVariant){
      // Teaser: only Spread + Total are eligible; ML and TT are empty
      row.appendChild(buildTeaserCell(game,team,'spread',team.spread,block,game));
      const mlEmpty=document.createElement('div');mlEmpty.className='tcell';mlEmpty.innerHTML='<span class="odash">—</span>';row.appendChild(mlEmpty);
      row.appendChild(buildTeaserCell(game,team,'total',team.total,block,game));
      const ttEmpty=document.createElement('div');ttEmpty.className='tcell';ttEmpty.innerHTML='<span class="odash">—</span>';row.appendChild(ttEmpty);
    } else {
      // straight + parlay + ifbet: all 4 markets including Team Total
      row.appendChild(buildOddsCell(game,team,'spread',team.spread,team.spVig,moved,block,game));
      row.appendChild(buildOddsCell(game,team,'ml',team.ml,'',moved,block,game));
      row.appendChild(buildOddsCell(game,team,'total',team.total,team.totVig,moved,block,game));
      row.appendChild(buildOddsCell(game,team,'tt',team.tt,team.ttVig,moved,block,game));
    }
    block.appendChild(row);
  });
  return block;
}

function buildOddsCell(game,team,mkey,line,vig,moved,blockEl,gameObj){
  const cell=document.createElement('div');cell.className='ocell';
  if(!line){cell.innerHTML='<span class="odash">—</span>';return cell;}
  const key=`${game.id}_${team.name}_${mkey}`;
  const isSel=!!selCells[key];
  const moveDir=moved.get(key);  // 'up' | 'dn' | undefined
  if(wagerMode==='straight'){
    // input box + odds button (LC797 straight style)
    const winVal=slip.find(s=>s.key===key)?.win||'';
    const lineNum=parseFloat(line);
    const movCls=moveDir&&!isSel?(moveDir==='up'?' mup':' mdn'):'';
    // Build input programmatically (no string-interpolated handler — safer for team names with quotes/HTML)
    const inp=document.createElement('input');
    inp.className='wager-inp';inp.type='number';inp.value=winVal;inp.min='20';inp.step='5';
    inp.title='Enter win amount';
    inp.addEventListener('input', e => onWinInput(key,game.id,team.name,game.sport,`${game.away} @ ${game.home}`,mkey,line,vig||'',e.target.value));
    cell.appendChild(inp);
    const arrowHtml=moveDir&&!isSel?`<span class="marr ${moveDir}">${moveDir==='up'?'▲':'▼'}</span>`:'';
    const btn=document.createElement('button');
    btn.className='obtn'+(isSel?' sel':'')+movCls;
    btn.innerHTML=`${arrowHtml}<span class="onum">${escapeHtml(line)}</span>${vig?`<span class="ovig">(${escapeHtml(vig)})</span>`:''}`;
    btn.onclick=()=>onOddsClickStraight(game,team,mkey,line,vig,key,blockEl,gameObj);
    cell.appendChild(btn);
  } else {
    // parlay or ifbet: plain button, goes dark when selected
    const btn=document.createElement('button');
    btn.className='pbtn'+(isSel?' sel':'');
    btn.textContent=`${line}${vig?' ('+vig+')':''}`;
    if(wagerMode==='ifbet') btn.onclick=()=>onIfBetClick(game,team,mkey,line,vig,key,blockEl,gameObj);
    else btn.onclick=()=>onOddsClickParlay(game,team,mkey,line,vig,key,blockEl,gameObj);
    cell.appendChild(btn);
  }
  return cell;
}

function onWinInput(key,gameId,teamName,sport,matchup,mkey,line,vig,winVal){
  const win=parseFloat(winVal)||0;
  const idx=slip.findIndex(s=>s.key===key);
  if(idx>-1){slip[idx].win=win;}
  else{selCells[key]=true;slip.push({key,gameId,teamName,sport,matchup,type:mkey,line,vig:vig||line,win});}
  if(win===0){delete selCells[key];slip=slip.filter(s=>s.key!==key);}
  updateContinueBtn();
}
function onOddsClickStraight(game,team,mkey,line,vig,key,blockEl,gameObj){
  // clicking the odds button just highlights it without changing amounts
  if(selCells[key]){delete selCells[key];slip=slip.filter(s=>s.key!==key);}
  else{selCells[key]=true;if(!slip.find(s=>s.key===key))slip.push({key,gameId:game.id,teamName:team.name,sport:game.sport,matchup:`${game.away} @ ${game.home}`,type:mkey,line,vig:vig||line,win:50});}
  updateContinueBtn();
  const nb=buildGameBlock(gameObj);blockEl.replaceWith(nb);
}
function onOddsClickParlay(game,team,mkey,line,vig,key,blockEl,gameObj){
  const idx=parlayLegs.findIndex(l=>l.key===key);
  if(idx>-1){parlayLegs.splice(idx,1);delete selCells[key];}
  else{parlayLegs.push({key,gameId:game.id,teamName:team.name,sport:game.sport,matchup:`${game.away} @ ${game.home}`,type:mkey,line,vig:vig||line});selCells[key]=true;}
  updateParlaySelections();
  const nb=buildGameBlock(gameObj);blockEl.replaceWith(nb);
}

function updateContinueBtn(){
  let n=0;
  if(wagerMode==='parlay') n=parlayLegs.length;
  else if(wagerMode==='teaser') n=teaserLegs.length;
  else if(wagerMode==='ifbet') n=ifBetLegs.length;
  else n=slip.filter(s=>s.win>0).length;
  const top=document.getElementById('continue-cnt');
  const brd=document.getElementById('brd-continue-cnt');
  top.textContent=`(${n})`;brd.textContent=`(${n})`;
  top.classList.toggle('h',n===0);brd.classList.toggle('h',n===0);
  const cb=document.getElementById('continue-btn');
  cb.style.opacity=n>0?'1':'0.5';
}

// ─── MODE ────────────────────────────────────────────
function setMode(mode){
  wagerMode=mode;
  document.getElementById('tab-straight').classList.toggle('active',mode==='straight');
  document.getElementById('tab-parlay').classList.toggle('active',mode==='parlay');
  document.getElementById('tab-teaser').classList.toggle('active',mode==='teaser');
  document.getElementById('tab-ifbet').classList.toggle('active',mode==='ifbet');
  // right panel: shown for parlay, teaser, and ifbet (selections); straight = no rail
  document.getElementById('sel-panel').style.display=(mode==='parlay'||mode==='teaser'||mode==='ifbet')?'flex':'none';
  // clear other slips when leaving them
  if(mode!=='straight'){slip.forEach(s=>delete selCells[s.key]);slip=[];}
  if(mode!=='parlay'){parlayLegs.forEach(l=>delete selCells[l.key]);parlayLegs=[];}
  if(mode!=='teaser'){teaserLegs.forEach(l=>delete selCells[l.key]);teaserLegs=[];teaserVariant=null;}
  if(mode!=='ifbet'){ifBetLegs.forEach(l=>delete selCells[l.key]);ifBetLegs=[];}
  // reset all tab badges + rail combined-odds box so stale state from prior mode doesn't leak
  ['par-badge','tea-badge','if-badge'].forEach(id=>{const el=document.getElementById(id);if(el){el.textContent='0';el.classList.add('h');}});
  document.getElementById('sel-combined').className='sel-combined h';
  document.getElementById('sel-legs').innerHTML='';
  const sc=document.getElementById('sel-continue');sc.textContent='(0) CONTINUE →';sc.className='sel-continue h';
  // limit display: parlay/teaser/ifbet enforce tighter per-leg caps
  const isP = mode==='parlay', isT = mode==='teaser', isI = mode==='ifbet';
  document.getElementById('lim-spread').textContent = (isP||isT||isI) ? '$100' : '$1000';
  document.getElementById('lim-ml').textContent     = (isP||isI) ? '$100' : (isT ? '—' : '$500');
  document.getElementById('lim-total').textContent  = (isP||isT||isI) ? '$100' : '$1000';
  document.getElementById('lim-tt').textContent     = (isP||isI) ? '$100' : (isT ? '—' : '$1000');
  // dim ML and TT cols in teaser (not eligible)
  document.getElementById('ch-ml').classList.toggle('disabled', isT);
  document.getElementById('ch-tt').classList.toggle('disabled', isT);
  // teaser menu visibility
  const onTeaserMenu = isT && !teaserVariant;
  document.getElementById('teaser-menu').style.display = onTeaserMenu ? 'block' : 'none';
  document.getElementById('col-hdrs').style.display = onTeaserMenu ? 'none' : 'grid';
  document.getElementById('board').style.display = onTeaserMenu ? 'none' : '';
  if(onTeaserMenu) renderTeaserMenu();
  // refresh selection panels
  if(mode==='parlay') updateParlaySelections();
  if(mode==='teaser' && teaserVariant) updateTeaserSelections();
  if(mode==='ifbet') updateIfBetSelections();
  updateContinueBtn();
  renderBoard();
}

function renderTeaserMenu(){
  const body=document.getElementById('tm-body');body.innerHTML='';
  TEASER_VARIANTS.forEach(v=>{
    const row=document.createElement('div');
    row.className='tm-row'+(v.enabled?'':' dis');
    const btn=document.createElement('button');
    btn.className='tm-vbtn';btn.textContent=v.label;btn.disabled=!v.enabled;
    if(v.enabled) btn.onclick=()=>selectTeaserVariant(v.key);
    const payLink=document.createElement('button');
    payLink.className='tm-link'+(v.enabled&&v.payouts?'':' dim');
    payLink.textContent='PAYOUTS';
    if(v.enabled&&v.payouts) payLink.onclick=()=>showTeaserPayouts(v.key);
    const sportsLink=document.createElement('button');
    sportsLink.className='tm-link dim';
    // PRIME 3T/4T are fixed-leg sweethearts; standard variants scale
    const legsTxt = v.minLegs===v.maxLegs ? `${v.minLegs} legs` : `${v.minLegs}–${v.maxLegs} legs`;
    sportsLink.textContent=`NBA + NFL · ${legsTxt}`;
    row.appendChild(btn);row.appendChild(payLink);row.appendChild(sportsLink);
    body.appendChild(row);
  });
}

function selectTeaserVariant(variantKey){
  teaserVariant=variantKey;
  teaserLegs.forEach(l=>delete selCells[l.key]);teaserLegs=[];
  document.getElementById('teaser-menu').style.display='none';
  document.getElementById('col-hdrs').style.display='grid';
  document.getElementById('board').style.display='';
  updateTeaserSelections();
  updateContinueBtn();
  renderBoard();
  showToast(`Teaser: ${getVariant(variantKey).label} active`);
}

function backToTeaserMenu(){
  teaserVariant=null;
  teaserLegs.forEach(l=>delete selCells[l.key]);teaserLegs=[];
  setMode('teaser');
}

// ─── PARLAY SELECTIONS PANEL ─────────────────────────
// Helper: write the continue button's count badge + dim state.
// The button has fixed inner structure (badge span + label + arrow),
// so we update the badge text instead of rewriting the whole element.
function setContinueState(n, minLegs, handler){
  const sc = document.getElementById('sel-continue');
  const cnt = document.getElementById('sel-continue-cnt');
  if(cnt) cnt.textContent = n;
  sc.classList.toggle('dim', n < minLegs);
  sc.onclick = handler;
}

function updateParlaySelections(){
  const n=parlayLegs.length;
  const badge=document.getElementById('par-badge');
  badge.textContent=n;badge.classList.toggle('h',n===0);
  setContinueState(n, 2, () => openParlayModal());
  updateContinueBtn();
  const combined=document.getElementById('sel-combined');
  combined.classList.toggle('show', n>=2);
  if(n>=2){
    const dec=parlayDec(parlayLegs);
    document.getElementById('sc-odds').textContent=dec.toFixed(3);
    document.getElementById('sc-am').textContent=`${decToAm(dec)} American`;
  }
  const legsCont=document.getElementById('sel-legs');legsCont.innerHTML='';
  if(n===0){
    legsCont.innerHTML='<div class="sel-empty"><strong>No legs yet</strong><span>Tap any odds on the board to start your parlay</span><small>Minimum 2 legs to place</small></div>';
    return;
  }
  parlayLegs.forEach(leg=>{
    const tl={spread:'Spread',ml:'Moneyline',total:'Total',tt:'Team Total'}[leg.type]||leg.type;
    const d=document.createElement('div');d.className='sel-leg';
    const initials=leg.teamName.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase();
    const oddsTxt = leg.vig && leg.vig !== leg.line
      ? `${escapeHtml(leg.line)} <span class="text-bet-text-xs">(${escapeHtml(leg.vig)})</span>`
      : escapeHtml(leg.line);
    d.innerHTML=`
      <div class="sel-logo">${escapeHtml(initials)}</div>
      <div class="sel-info">
        <div class="sel-team">${escapeHtml(leg.teamName)}</div>
        <div class="sel-sub">${tl} · <strong>${oddsTxt}</strong></div>
      </div>
      <button class="sel-rm" data-key="${escapeHtml(leg.key)}" title="Remove leg">✕</button>`;
    d.querySelector('.sel-rm').addEventListener('click', e => removeParlayLeg(e.currentTarget.dataset.key));
    legsCont.appendChild(d);
  });
}
function clearParlay(){parlayLegs.forEach(l=>delete selCells[l.key]);parlayLegs=[];updateParlaySelections();renderBoard();}
function removeParlayLeg(key){delete selCells[key];parlayLegs=parlayLegs.filter(l=>l.key!==key);updateParlaySelections();renderBoard();}
function clearSelections(){
  if(wagerMode==='teaser') clearTeaser();
  else if(wagerMode==='ifbet') clearIfBet();
  else clearParlay();
}

// ─── IF BET ──────────────────────────────────────────
function onIfBetClick(game,team,mkey,line,vig,key,blockEl,gameObj){
  const idx=ifBetLegs.findIndex(l=>l.key===key);
  if(idx>-1){
    ifBetLegs.splice(idx,1);delete selCells[key];
  } else {
    if(ifBetLegs.length>=8){showToast('Max 8 legs in an If Bet');return;}
    ifBetLegs.push({key,gameId:game.id,teamName:team.name,sport:game.sport,matchup:`${game.away} @ ${game.home}`,type:mkey,line,vig:vig||line,win:50,fireRule:'win'});
    selCells[key]=true;
  }
  updateIfBetSelections();
  const nb=buildGameBlock(gameObj);blockEl.replaceWith(nb);
}
function clearIfBet(){ifBetLegs.forEach(l=>delete selCells[l.key]);ifBetLegs=[];updateIfBetSelections();renderBoard();}
function removeIfBetLeg(key){delete selCells[key];ifBetLegs=ifBetLegs.filter(l=>l.key!==key);updateIfBetSelections();renderBoard();}

function updateIfBetSelections(){
  const n=ifBetLegs.length;
  const ifBadge=document.getElementById('if-badge');
  ifBadge.textContent=n;ifBadge.classList.toggle('h',n===0);
  setContinueState(n, 2, () => openIfBetModal());
  document.getElementById('sel-combined').classList.remove('show');
  const legsCont=document.getElementById('sel-legs');legsCont.innerHTML='';
  if(n===0){
    legsCont.innerHTML='<div class="sel-empty"><strong>If Bet builder</strong><span>Tap any odds to add legs in sequence</span><small>Each leg fires only if the previous one wins · Min 2 legs</small></div>';
    updateContinueBtn();return;
  }
  ifBetLegs.forEach((leg,i)=>{
    const tl={spread:'Spread',ml:'Moneyline',total:'Total',tt:'Team Total'}[leg.type]||leg.type;
    const d=document.createElement('div');d.className='sel-leg';
    // For ifbet, the leading badge is a sequence number rather than initials
    // — orders matter (leg 1 fires first, leg 2 only if leg 1 wins, etc.)
    const oddsTxt = leg.vig && leg.vig !== leg.line
      ? `${escapeHtml(leg.line)} <span class="text-bet-text-xs">(${escapeHtml(leg.vig)})</span>`
      : escapeHtml(leg.line);
    d.innerHTML=`
      <div class="sel-logo numbered">${i+1}</div>
      <div class="sel-info">
        <div class="sel-team">${escapeHtml(leg.teamName)}</div>
        <div class="sel-sub">${tl} · <strong>${oddsTxt}</strong></div>
      </div>
      <button class="sel-rm" data-key="${escapeHtml(leg.key)}" title="Remove leg">✕</button>`;
    d.querySelector('.sel-rm').addEventListener('click', e => removeIfBetLeg(e.currentTarget.dataset.key));
    legsCont.appendChild(d);
  });
  updateContinueBtn();
}

function openIfBetModal(){
  const n=ifBetLegs.length;
  if(n<2){showToast('Min 2 legs for an If Bet');return;}
  document.getElementById('iftitle').textContent=`${n}-Leg If Bet`;
  renderIFLegs();
  document.getElementById('ifoverlay').classList.add('open');
}
function closeIF(){document.getElementById('ifoverlay').classList.remove('open');}

function renderIFLegs(){
  const cont=document.getElementById('iflegs');cont.innerHTML='';
  ifBetLegs.forEach((leg,i)=>{
    const tl={spread:'Spread',ml:'ML',total:'Total',tt:'TT'}[leg.type]||leg.type;
    const win=parseFloat(leg.win)||0;
    const risk=calcRisk(win,leg.vig||leg.line);
    const row=document.createElement('div');row.className='if-leg';
    const ruleLabel=leg.fireRule==='winOrPush'?'IF WIN/PUSH':'IF WIN';
    const ruleTitle=i===0?'Leg 1 always fires':`Fires only if leg ${i} ${leg.fireRule==='winOrPush'?'wins or pushes':'wins'}`;
    row.innerHTML=`
      <div class="if-leg-num">${i+1}</div>
      <div class="if-leg-info">
        <div class="if-leg-team">${escapeHtml(leg.teamName)} <span style="color:var(--text-xs);font-weight:400">${tl} ${escapeHtml(leg.line)}${leg.vig&&leg.vig!==leg.line?' ('+escapeHtml(leg.vig)+')':''}</span></div>
        <div class="if-leg-sub">${escapeHtml(leg.matchup)} · Risk ${fmtUSD(risk)} · ${i===0?'Leg 1 always fires':ruleTitle}</div>
      </div>
      <input class="rv-win-inp" type="number" value="${win.toFixed(2)}" min="20" step="5" data-idx="${i}" style="width:70px;text-align:right;font-family:var(--fh);font-weight:700">
      ${i===0?'<div style="text-align:center;font-size:9px;color:var(--text-xs)">FIRST LEG</div>':`<button class="if-leg-rule" data-idx="${i}" title="Toggle fire rule">${ruleLabel}</button>`}
      <button class="if-leg-rm" data-idx="${i}">✕</button>`;
    row.querySelector('.rv-win-inp').addEventListener('input', e => updateIFLegWin(parseInt(e.currentTarget.dataset.idx), e.currentTarget.value));
    if(i>0) row.querySelector('.if-leg-rule').addEventListener('click', e => toggleIFLegRule(parseInt(e.currentTarget.dataset.idx)));
    row.querySelector('.if-leg-rm').addEventListener('click', e => removeIFLegFromModal(parseInt(e.currentTarget.dataset.idx)));
    cont.appendChild(row);
  });
  updateIFTotals();
}

function updateIFLegWin(idx,val){
  if(!ifBetLegs[idx]) return;
  ifBetLegs[idx].win=parseFloat(val)||0;
  updateIFTotals();
}
function toggleIFLegRule(idx){
  if(!ifBetLegs[idx]) return;
  ifBetLegs[idx].fireRule = ifBetLegs[idx].fireRule==='winOrPush' ? 'win' : 'winOrPush';
  renderIFLegs();
}
function removeIFLegFromModal(idx){
  if(!ifBetLegs[idx]) return;
  delete selCells[ifBetLegs[idx].key];
  ifBetLegs.splice(idx,1);
  if(ifBetLegs.length<2){closeIF();updateIfBetSelections();renderBoard();return;}
  renderIFLegs();updateIfBetSelections();renderBoard();
}
function updateIFTotals(){
  // Total risk = leg 1 risk only (subsequent legs come from prior winnings)
  // Total potential win = sum of all leg wins (assuming all hit)
  if(!ifBetLegs.length){
    document.getElementById('if-totrisk').textContent='$0.00';
    document.getElementById('if-totwin').textContent='$0.00';return;
  }
  const leg1=ifBetLegs[0];
  const leg1Risk=calcRisk(parseFloat(leg1.win)||0, leg1.vig||leg1.line);
  const totalWin=ifBetLegs.reduce((a,l)=>a+(parseFloat(l.win)||0),0);
  document.getElementById('if-totrisk').textContent=fmtUSD(leg1Risk);
  document.getElementById('if-totwin').textContent=fmtUSD(totalWin);
  const valEl=document.getElementById('if-val');
  const minOk=ifBetLegs.every(l=>(parseFloat(l.win)||0)>=20);
  const balOk=leg1Risk<=balance;
  valEl.textContent = !minOk ? '⚠ Each leg must win at least $20' : (!balOk ? '⚠ Leg 1 risk exceeds balance' : '');
  const btn=document.getElementById('if-confirm');
  btn.disabled = !minOk || !balOk;
  btn.textContent = !balOk ? 'Insufficient balance' : `Place ${ifBetLegs.length}-Leg If Bet →`;
}
function confirmIfBet(){
  const n=ifBetLegs.length;
  if(n<2){showToast('Min 2 legs');return;}
  if(!ifBetLegs.every(l=>(parseFloat(l.win)||0)>=20)){showToast('Each leg must win at least $20');return;}
  const leg1Risk=calcRisk(parseFloat(ifBetLegs[0].win)||0, ifBetLegs[0].vig||ifBetLegs[0].line);
  if(leg1Risk>balance){showToast('Insufficient balance');return;}
  const totalWin=ifBetLegs.reduce((a,l)=>a+(parseFloat(l.win)||0),0);
  balance-=leg1Risk;
  placedBets.push({type:'ifbet',legs:ifBetLegs.map(l=>({teamName:l.teamName,matchup:l.matchup,type:l.type,line:l.line,vig:l.vig,win:l.win,fireRule:l.fireRule,sport:l.sport})),legCount:n,risk:leg1Risk,win:totalWin,placed:new Date().toLocaleString(),status:'pending'});
  localStorage.setItem('bs_bets',JSON.stringify(placedBets));localStorage.setItem('bs_bal',balance);
  ifBetLegs.forEach(l=>delete selCells[l.key]);ifBetLegs=[];
  updateIfBetSelections();updateBalDisp();updateBetsBtn();renderBoard();closeIF();
  showToast(`✓ ${n}-leg if bet placed! Risk ${fmtUSD(leg1Risk)} → potential win ${fmtUSD(totalWin)}`);
}

// ─── TEASER CELLS + SELECTIONS ───────────────────────
function buildTeaserCell(game,team,mkey,line,blockEl,gameObj){
  const cell=document.createElement('div');cell.className='tcell';
  if(!line){cell.innerHTML='<span class="odash">—</span>';return cell;}
  const v=getVariant(teaserVariant);
  const shifted=teaserShift(line,mkey,v,game.sport);
  if(!shifted){cell.innerHTML='<span class="odash">—</span>';return cell;}
  const key=`${game.id}_${team.name}_${mkey}_T`;
  const isSel=!!selCells[key];
  const btn=document.createElement('button');
  btn.className='tbtn'+(isSel?' sel':'');
  btn.innerHTML=`<span class="torig">${escapeHtml(line)}</span> <strong>${escapeHtml(shifted)}</strong>`;
  btn.title=`Original ${line} → teased ${shifted} (${v.label})`;
  btn.onclick=()=>onTeaserClick(game,team,mkey,line,shifted,key,blockEl,gameObj);
  cell.appendChild(btn);
  return cell;
}

function onTeaserClick(game,team,mkey,origLine,shiftedLine,key,blockEl,gameObj){
  const v=getVariant(teaserVariant);
  const idx=teaserLegs.findIndex(l=>l.key===key);
  if(idx>-1){
    teaserLegs.splice(idx,1);delete selCells[key];
  } else {
    if(teaserLegs.length>=v.maxLegs){showToast(`Max ${v.maxLegs} legs for ${v.label}`);return;}
    teaserLegs.push({key,gameId:game.id,teamName:team.name,sport:game.sport,matchup:`${game.away} @ ${game.home}`,type:mkey,origLine,shiftedLine});
    selCells[key]=true;
  }
  updateTeaserSelections();
  const nb=buildGameBlock(gameObj);blockEl.replaceWith(nb);
}

function updateTeaserSelections(){
  const n=teaserLegs.length;
  const v=teaserVariant?getVariant(teaserVariant):null;
  const teaBadge=document.getElementById('tea-badge');
  teaBadge.textContent=n;teaBadge.classList.toggle('h',n===0);
  const minLegs=v?v.minLegs:2;
  setContinueState(n, minLegs, () => openTeaserModal());
  document.getElementById('sel-combined').classList.remove('show');
  const legsCont=document.getElementById('sel-legs');legsCont.innerHTML='';
  if(n===0){
    legsCont.innerHTML=`<div class="sel-empty"><strong>${v?escapeHtml(v.label):'Teaser'} builder</strong><span>Tap any spread or total to add legs</span><small>Lines shift in your favor · Min ${minLegs} legs</small></div>`;
    updateContinueBtn();return;
  }
  teaserLegs.forEach(leg=>{
    const tl={spread:'Spread',total:'Total'}[leg.type]||leg.type;
    const d=document.createElement('div');d.className='sel-leg';
    const initials=leg.teamName.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase();
    d.innerHTML=`
      <div class="sel-logo">${escapeHtml(initials)}</div>
      <div class="sel-info">
        <div class="sel-team">${escapeHtml(leg.teamName)}</div>
        <div class="sel-sub">${tl}: <span class="torig">${escapeHtml(leg.origLine)}</span> → <strong>${escapeHtml(leg.shiftedLine)}</strong></div>
      </div>
      <button class="sel-rm" data-key="${escapeHtml(leg.key)}" title="Remove leg">✕</button>`;
    d.querySelector('.sel-rm').addEventListener('click', e => removeTeaserLeg(e.currentTarget.dataset.key));
    legsCont.appendChild(d);
  });
  updateContinueBtn();
}

function removeTeaserLeg(key){delete selCells[key];teaserLegs=teaserLegs.filter(l=>l.key!==key);updateTeaserSelections();renderBoard();}
function clearTeaser(){teaserLegs.forEach(l=>delete selCells[l.key]);teaserLegs=[];updateTeaserSelections();renderBoard();}

// ─── TEASER PAYOUTS MODAL ────────────────────────────
function showTeaserPayouts(variantKey){
  const v=getVariant(variantKey);
  if(!v||!v.payouts) return;
  document.getElementById('tpay-title').textContent=v.label;
  const legsTxt = v.minLegs===v.maxLegs ? `${v.minLegs} legs (fixed)` : `${v.minLegs}–${v.maxLegs} legs`;
  document.getElementById('tpay-sub').textContent=`${v.ftbShift} pt Football & ${v.bbShift} pt Basketball · ${legsTxt}`;
  const body=document.getElementById('tpay-body');body.innerHTML='';
  Object.keys(v.payouts).forEach(legCount=>{
    const am=v.payouts[legCount];
    const dec=toDec(am);
    const risk=am.startsWith('-')?Math.abs(parseFloat(am)):100;
    const win=am.startsWith('-')?100:parseFloat(am.replace('+',''));
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>${legCount}</td><td>${legCount}</td><td>${risk}</td><td>${win}</td>`;
    body.appendChild(tr);
  });
  document.getElementById('tpay-overlay').classList.add('open');
}
function closeTeaserPayouts(){document.getElementById('tpay-overlay').classList.remove('open');}

// ─── TEASER REVIEW MODAL ─────────────────────────────
function openTeaserModal(){
  const v=getVariant(teaserVariant);
  const n=teaserLegs.length;
  if(n<v.minLegs){showToast(`Min ${v.minLegs} legs for ${v.label}`);return;}
  document.getElementById('tmtitle').textContent=`${n}-Pick Teaser · ${v.label}`;
  const am=teaserPayout(v,n);
  document.getElementById('tm-am').textContent=am||'—';
  const lc=document.getElementById('tmlegs');lc.innerHTML='';
  teaserLegs.forEach(leg=>{
    const tl={spread:'Spread',total:'Total'}[leg.type]||leg.type;
    const initials=leg.teamName.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase();
    const d=document.createElement('div');d.className='pmleg';
    d.innerHTML=`<div class="pmlogo">${escapeHtml(initials)}</div><div class="pmteam">${escapeHtml(leg.teamName)} <span style="font-size:10px;color:var(--text-xs);font-weight:400">${tl}</span></div><div class="pmodds"><span style="text-decoration:line-through;color:var(--text-xs);font-size:11px;font-weight:400">${escapeHtml(leg.origLine)}</span> ${escapeHtml(leg.shiftedLine)}</div>`;
    lc.appendChild(d);
  });
  document.getElementById('tm-risk').value='20';
  updateTMCalc();
  document.getElementById('tmoverlay').classList.add('open');
}
function closeTM(){document.getElementById('tmoverlay').classList.remove('open');}
function updateTMCalc(){
  const v=getVariant(teaserVariant);
  const n=teaserLegs.length;
  const inp=document.getElementById('tm-risk');
  const risk=parseFloat(inp.value)||0;
  const am=teaserPayout(v,n);
  if(!am||n<v.minLegs){document.getElementById('tm-win').textContent='$0.00';return;}
  const win=calcWin(risk,am);
  document.getElementById('tm-win').textContent=fmtUSD(win);
  const invalid = risk<20 || risk>balance;
  inp.classList.toggle('invalid', invalid && inp.value!=='');
  document.getElementById('tm-val').textContent = risk<20 ? '⚠ Minimum wager is $20' : (risk>balance ? '⚠ Exceeds balance' : '');
  const btn=document.getElementById('tm-confirm');
  btn.disabled=n<v.minLegs||risk<20||risk>balance;
  btn.textContent=risk>balance?'Insufficient balance':`Place ${n}-Pick Teaser →`;
}
function confirmTeaser(){
  const v=getVariant(teaserVariant);
  const n=teaserLegs.length;
  const risk=parseFloat(document.getElementById('tm-risk').value)||0;
  const am=teaserPayout(v,n);
  if(!am){showToast('Invalid leg count for variant');return;}
  if(risk<20){showToast('Min $20');return;}
  if(risk>balance){showToast('Insufficient balance');return;}
  const win=calcWin(risk,am);
  balance-=risk;
  placedBets.push({type:'teaser',variant:v.label,legs:teaserLegs.map(l=>({teamName:l.teamName,matchup:l.matchup,type:l.type,origLine:l.origLine,line:l.shiftedLine,sport:l.sport})),legCount:n,amOdds:am,risk,win,placed:new Date().toLocaleString(),status:'pending'});
  localStorage.setItem('bs_bets',JSON.stringify(placedBets));localStorage.setItem('bs_bal',balance);
  teaserLegs.forEach(l=>delete selCells[l.key]);teaserLegs=[];
  updateTeaserSelections();updateBalDisp();updateBetsBtn();renderBoard();closeTM();
  showToast(`✓ ${n}-pick ${v.label} teaser placed! To win ${fmtUSD(win)}`);
}

// ─── CONTINUE (straight → review screen) ─────────────
function onContinue(){
  if(wagerMode==='parlay'){openParlayModal();return;}
  if(wagerMode==='teaser'){
    if(!teaserVariant){showToast('Pick a teaser variant from the menu first');return;}
    openTeaserModal();return;
  }
  if(wagerMode==='ifbet'){openIfBetModal();return;}
  const valid=slip.filter(s=>s.win>0);
  if(!valid.length){showToast('Enter a win amount for at least one wager');return;}
  renderReview();
  document.getElementById('main-layout').style.display='none';
  document.getElementById('review-screen').classList.add('active');
}
function closeReview(){
  document.getElementById('main-layout').style.display='flex';
  document.getElementById('review-screen').classList.remove('active');
}

function renderReview(){
  const tbody=document.getElementById('rv-body');tbody.innerHTML='';
  let totWin=0,totRisk=0;
  slip.filter(s=>s.win>0).forEach(s=>{
    const win=parseFloat(s.win)||0;
    const risk=calcRisk(win,s.vig||s.line);
    totWin+=win;totRisk+=risk;
    const tl={spread:'Spread',ml:'Moneyline',total:'Total/OU',tt:'Team Total'}[s.type]||s.type;
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td class="rv-td"><div class="rv-team"><button class="rv-rm" data-key="${escapeHtml(s.key)}">✕</button>${escapeHtml(s.teamName)}</div><div style="font-size:10px;color:var(--text-xs)">${escapeHtml(s.matchup)} · ${tl}</div></td>
      <td class="rv-td"><select class="rv-odds-sel"><option>${escapeHtml(s.line)}${s.vig&&s.vig!==s.line?' ('+escapeHtml(s.vig)+')':''}</option></select></td>
      <td class="rv-td" style="text-align:right"><input class="rv-win-inp" type="number" value="${win.toFixed(2)}" min="20" step="5" data-key="${escapeHtml(s.key)}"><div class="rv-val">${win<20?'⚠ Min $20':''}</div></td>
      <td class="rv-td"><div class="rv-risk">${fmtUSD(risk)}</div></td>`;
    tr.querySelector('.rv-rm').addEventListener('click', e => removeFromSlip(e.currentTarget.dataset.key));
    tr.querySelector('.rv-win-inp').addEventListener('input', e => updateSlipWin(e.currentTarget.dataset.key, e.currentTarget.value));
    tbody.appendChild(tr);
  });
  document.getElementById('rv-summary').innerHTML=`Total Win: <span>${fmtUSD(totWin)}</span> &nbsp;|&nbsp; Total Risk: <span style="color:var(--red)">${fmtUSD(totRisk)}</span> &nbsp;|&nbsp; Balance After: <span>${fmtUSD(balance-totRisk)}</span>`;
}
function updateSlipWin(key,val){
  const idx=slip.findIndex(s=>s.key===key);
  if(idx>-1){slip[idx].win=parseFloat(val)||0;renderReview();}
}
function removeFromSlip(key){
  delete selCells[key];slip=slip.filter(s=>s.key!==key);
  if(!slip.length){closeReview();renderBoard();return;}
  renderReview();renderBoard();
}
function confirmWagers(){
  const valid=slip.filter(s=>(parseFloat(s.win)||0)>=20);
  if(!valid.length){showToast('Minimum win amount is $20');return;}
  const totRisk=valid.reduce((a,s)=>a+calcRisk(parseFloat(s.win)||0,s.vig||s.line),0);
  if(totRisk>balance){showToast('Insufficient balance');return;}
  balance-=totRisk;
  const now=new Date().toLocaleString();
  valid.forEach(s=>{const risk=calcRisk(parseFloat(s.win)||0,s.vig||s.line);placedBets.push({...s,type:'straight',risk,placed:now,status:'pending'});});
  localStorage.setItem('bs_bets',JSON.stringify(placedBets));localStorage.setItem('bs_bal',balance);
  slip=[];selCells={};updateContinueBtn();updateBalDisp();updateBetsBtn();renderBoard();closeReview();
  showToast('✓ Wager placed! Good luck.');
}

// ─── PARLAY MODAL ────────────────────────────────────
function openParlayModal(){
  if(parlayLegs.length<2){showToast('Select at least 2 legs');return;}
  const n=parlayLegs.length;
  document.getElementById('pmtitle').textContent=`${n} Team – Parlay`;
  const lc=document.getElementById('pmlegs');lc.innerHTML='';
  parlayLegs.forEach(leg=>{
    const d=document.createElement('div');d.className='pmleg';
    const initials=leg.teamName.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase();
    d.innerHTML=`<div class="pmlogo">${escapeHtml(initials)}</div><div class="pmteam">${escapeHtml(leg.teamName)}</div><div class="pmodds">${escapeHtml(leg.line)}${leg.vig&&leg.vig!==leg.line?' ('+escapeHtml(leg.vig)+')':''}</div>`;
    lc.appendChild(d);
  });
  const gids=parlayLegs.map(l=>l.gameId);
  document.getElementById('corr').classList.toggle('h',gids.length===new Set(gids).size);
  document.getElementById('pm-risk').value='20';
  updatePMCalc();
  document.getElementById('pmoverlay').classList.add('open');
}
function closePM(){document.getElementById('pmoverlay').classList.remove('open');}
function updatePMCalc(){
  const inp=document.getElementById('pm-risk');
  const risk=parseFloat(inp.value)||0;
  const n=parlayLegs.length;
  if(n<2){document.getElementById('pm-win').textContent='$0.00';return;}
  const dec=parlayDec(parlayLegs);
  const win=(dec-1)*risk;
  document.getElementById('pm-win').textContent=fmtUSD(win);
  const invalid = risk<20 || risk>balance;
  inp.classList.toggle('invalid', invalid && inp.value!=='');
  document.getElementById('pm-val').textContent = risk<20 ? '⚠ Minimum wager is $20' : (risk>balance ? '⚠ Exceeds balance' : '');
  const btn=document.getElementById('pm-confirm');
  btn.disabled=n<2||risk<20||risk>balance;
  btn.textContent=risk>balance?'Insufficient balance':`Place ${n}-Leg Parlay →`;
}
function confirmParlay(){
  const risk=parseFloat(document.getElementById('pm-risk').value)||0;
  if(risk<20){showToast('Min $20');return;}
  if(risk>balance){showToast('Insufficient balance');return;}
  const dec=parlayDec(parlayLegs),win=(dec-1)*risk;
  balance-=risk;
  placedBets.push({type:'parlay',legs:parlayLegs.map(l=>({teamName:l.teamName,matchup:l.matchup,type:l.type,line:l.line,vig:l.vig})),legCount:parlayLegs.length,decOdds:dec,amOdds:decToAm(dec),risk,win,placed:new Date().toLocaleString(),status:'pending'});
  localStorage.setItem('bs_bets',JSON.stringify(placedBets));localStorage.setItem('bs_bal',balance);
  parlayLegs.forEach(l=>delete selCells[l.key]);parlayLegs=[];
  updateParlaySelections();updateBalDisp();updateBetsBtn();renderBoard();closePM();
  showToast(`✓ ${placedBets[placedBets.length-1].legCount}-leg parlay placed! To win ${fmtUSD(win)}`);
}

// ─── PENDING BETS COUNT ──────────────────────────────
function updateBetsBtn(){
  const n=placedBets.filter(b=>b.status==='pending').length;
  const cnt=document.getElementById('bets-cnt');
  cnt.style.display=n?'inline':'none';cnt.textContent=n;
  const ps=document.getElementById('pend-stat');if(ps)ps.style.display=n?'block':'none';
  const pd=document.getElementById('pend-disp');if(pd)pd.textContent=n;
}

// ─── MY BETS ─────────────────────────────────────────
function openBets(){renderBetsModal();document.getElementById('bmodal-overlay').classList.add('open');}
function closeBets(){document.getElementById('bmodal-overlay').classList.remove('open');}
function renderBetsModal(){
  const body=document.getElementById('bmodal-body');body.innerHTML='';
  if(!placedBets.length){body.innerHTML='<div style="text-align:center;color:var(--text-xs);padding:40px">No bets placed yet.</div>';return;}
  // Pair each bet with its original index so we can settle by index regardless of reverse-render order
  placedBets.map((b,i)=>({b,i})).reverse().forEach(({b,i})=>{
    const card=document.createElement('div');card.className='betcard';
    if(b.type==='ifbet'){
      const totWin=b.win||((b.legs||[]).reduce((a,l)=>a+(parseFloat(l.win)||0),0));
      card.innerHTML=`<div class="bettop"><span class="bettnm">⛓ ${b.legCount}-Leg If Bet</span><span class="betst ${b.status}">${escapeHtml(b.status.toUpperCase())}</span></div><div class="betmeta">Sequential · ${escapeHtml(b.placed||'')}</div><div class="plegprev">${(b.legs||[]).map((l,i)=>{const tl={spread:'Spread',ml:'ML',total:'Total',tt:'TT'}[l.type]||l.type;const rule=i===0?'always':(l.fireRule==='winOrPush'?'if win/push':'if win');return`<div class="plegprevrow"><b style="color:var(--orange)">${i+1}.</b> ${escapeHtml(l.teamName)} <span style="color:var(--text-xs)">(${tl}: ${escapeHtml(l.line)} · win ${fmtUSD(parseFloat(l.win)||0)} · ${rule})</span></div>`;}).join('')}</div><div class="betamts"><div class="betamt"><label>Risk (Leg 1)</label><div class="bamt r">${fmtUSD(b.risk)}</div></div><div class="betamt"><label>Max Win</label><div class="bamt g">${fmtUSD(totWin)}</div></div></div>`;
    } else if(b.type==='teaser'){
      const win=b.win||calcWin(b.risk||0,b.amOdds||'-110');
      card.innerHTML=`<div class="bettop"><span class="bettnm">🎯 ${b.legCount}-Pick ${escapeHtml(b.variant||'Teaser')}</span><span class="betst ${b.status}">${escapeHtml(b.status.toUpperCase())}</span></div><div class="betmeta">Odds: ${escapeHtml(b.amOdds||'')} · ${escapeHtml(b.placed||'')}</div><div class="plegprev">${(b.legs||[]).map((l,i)=>{const tl={spread:'Spread',total:'Total'}[l.type]||l.type;return`<div class="plegprevrow"><b style="color:var(--teal)">${i+1}.</b> ${escapeHtml(l.teamName)} <span style="color:var(--text-xs)">(${tl}: <span style="text-decoration:line-through">${escapeHtml(l.origLine||'')}</span> → ${escapeHtml(l.line)})</span></div>`;}).join('')}</div><div class="betamts"><div class="betamt"><label>Risk</label><div class="bamt r">${fmtUSD(b.risk)}</div></div><div class="betamt"><label>To Win</label><div class="bamt g">${fmtUSD(win)}</div></div></div>`;
    } else if(b.type==='parlay'||b.legCount){
      const win=b.win||((b.decOdds-1)*b.risk);
      card.innerHTML=`<div class="bettop"><span class="bettnm">🎰 ${b.legCount}-Leg Parlay</span><span class="betst ${b.status}">${escapeHtml(b.status.toUpperCase())}</span></div><div class="betmeta">Odds: ${escapeHtml(b.amOdds)} (${parseFloat(b.decOdds).toFixed(3)}x) · ${escapeHtml(b.placed||'')}</div><div class="plegprev">${(b.legs||[]).map((l,i)=>{const tl={spread:'Spread',ml:'ML',total:'Total',tt:'TT'}[l.type]||l.type;return`<div class="plegprevrow"><b style="color:var(--teal)">${i+1}.</b> ${escapeHtml(l.teamName)} <span style="color:var(--text-xs)">(${tl}: ${escapeHtml(l.line)}${l.vig&&l.vig!==l.line?' '+escapeHtml(l.vig):''})</span></div>`;}).join('')}</div><div class="betamts"><div class="betamt"><label>Risk</label><div class="bamt r">${fmtUSD(b.risk)}</div></div><div class="betamt"><label>To Win</label><div class="bamt g">${fmtUSD(win)}</div></div></div>`;
    } else {
      const win=b.win||calcWin(b.risk||0,b.vig||b.line);const risk=b.risk||calcRisk(b.win||0,b.vig||b.line);
      const tl={spread:'Spread',ml:'Moneyline',total:'Total/OU',tt:'Team Total'}[b.type]||b.type;
      card.innerHTML=`<div class="bettop"><span class="bettnm">${escapeHtml(b.teamName)}</span><span class="betst ${b.status}">${escapeHtml(b.status.toUpperCase())}</span></div><div class="betmeta">${escapeHtml(b.sport)} · ${tl}: ${escapeHtml(b.line)}${b.vig&&b.vig!==b.line?' ('+escapeHtml(b.vig)+')':''} · ${escapeHtml(b.placed||'')}</div><div class="betamts"><div class="betamt"><label>Risk</label><div class="bamt r">${fmtUSD(risk)}</div></div><div class="betamt"><label>To Win</label><div class="bamt g">${fmtUSD(win)}</div></div></div>`;
    }
    // Settlement controls — only on pending tickets
    if(b.status==='pending'){
      const sr=document.createElement('div');sr.className='settle-row';
      sr.innerHTML=`<button class="settle-btn won" data-idx="${i}" data-outcome="won">✓ Won</button><button class="settle-btn push" data-idx="${i}" data-outcome="push">↺ Push</button><button class="settle-btn lost" data-idx="${i}" data-outcome="lost">✕ Lost</button>`;
      sr.querySelectorAll('.settle-btn').forEach(btn=>{
        btn.addEventListener('click', e=>settleBet(parseInt(e.currentTarget.dataset.idx,10), e.currentTarget.dataset.outcome));
      });
      card.appendChild(sr);
    }
    body.appendChild(card);
  });
}

// ─── BET SETTLEMENT ──────────────────────────────────
// outcome: 'won' | 'lost' | 'push'
// Payout rules (entertainment-only — simulator simplification):
//   won  → balance += risk + win (return stake plus winnings)
//   lost → balance += 0          (risk was already deducted at placement)
//   push → balance += risk       (return stake only)
// For if-bets, "won" assumes all legs hit (full chain pays out); per-leg
// resolution is out of scope here — keep it as a single-ticket outcome.
function settleBet(idx, outcome){
  const b=placedBets[idx];
  if(!b||b.status!=='pending') return;
  if(outcome==='won'){balance += b.risk + b.win;}
  else if(outcome==='push'){balance += b.risk;}
  // 'lost' → no balance change (risk was deducted at placement)
  b.status = outcome;
  b.settled = new Date().toLocaleString();
  localStorage.setItem('bs_bets', JSON.stringify(placedBets));
  localStorage.setItem('bs_bal', balance);
  updateBalDisp();
  updateBetsBtn();
  renderBetsModal();
  showToast(`Bet marked as ${outcome.toUpperCase()}`);
}

// ─── SETTINGS DRAWER ─────────────────────────────────
function openSettings(){
  const inp = document.getElementById('api-key-inp');
  if(inp) inp.value = apiKey || '';
  const sel = document.getElementById('book-sel');
  if(sel) sel.value = prefBook;
  const cbx = document.getElementById('mock-cbx');
  if(cbx){
    cbx.checked = mockMode;
    cbx.disabled = !window.MOCK_DATA;
    const ms = document.getElementById('mock-status');
    if(ms) ms.textContent = window.MOCK_DATA
      ? (mockMode ? 'Active — using captured fixture' : 'Use captured fixture data — no API calls')
      : 'Fixture (mock_data.js) not loaded';
  }
  const sb = document.getElementById('set-bal');
  if(sb) sb.textContent = fmtUSD(balance);
  // Quota bar
  const qbar = document.getElementById('qbar');
  const qu = document.getElementById('q-used'), qr = document.getElementById('q-rem');
  if(qbar){ const pct = qRem ? Math.min(100, (qUsed / (qUsed + qRem)) * 100) : 0; qbar.style.width = pct + '%'; }
  if(qu) qu.textContent = `${qUsed} used`;
  if(qr) qr.textContent = `${qRem} remaining`;
  document.getElementById('set-overlay').classList.add('open');
}
function closeSettings(){ document.getElementById('set-overlay').classList.remove('open'); }

function saveApiKey(){
  const v = document.getElementById('api-key-inp').value.trim();
  apiKey = v;
  localStorage.setItem('bs_key', v);
  if(v){ setOnline(true); showToast('API key saved'); fetchAndRender(); }
  else { setOnline(false); showToast('API key cleared'); }
  closeSettings();
}

function saveBook(){
  prefBook = document.getElementById('book-sel').value;
  localStorage.setItem('bs_book', prefBook);
  // Force re-fetch since odds shape varies per bookmaker
  gamesCache = {};
  fetchAndRender();
  showToast(`Bookmaker: ${prefBook}`);
}

function toggleMockMode(){
  const cbx = document.getElementById('mock-cbx');
  if(!cbx) return;
  if(cbx.checked && !window.MOCK_DATA){
    cbx.checked = false;
    showToast('Mock data not available');
    return;
  }
  mockMode = cbx.checked;
  localStorage.setItem('bs_mock', mockMode ? '1' : '0');
  gamesCache = {};
  setOnline(mockMode || !!apiKey);
  fetchAndRender();
  showToast(mockMode ? 'Mock Mode ON' : 'Mock Mode OFF');
}

function resetBalance(){
  if(!confirm('Reset virtual balance to $1,000? This does not affect placed bets.')) return;
  balance = 1000;
  localStorage.setItem('bs_bal', balance);
  updateBalDisp();
  const sb = document.getElementById('set-bal');
  if(sb) sb.textContent = fmtUSD(balance);
  showToast('Balance reset to $1,000');
}

// ─── DISPLAYS / TOAST / FILTER ──────────────────────
function updateBalDisp(){
  const el = document.getElementById('bal-disp');
  if(el) el.textContent = fmtUSD(balance);
}

let _toastTimer = null;
function showToast(msg){
  const t = document.getElementById('toast');
  if(!t) return;
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => t.classList.remove('show'), 2400);
}

function filterSport(sport){
  // 'all' shows every group; otherwise show only matching SPORT_CFG entries.
  // Sidebar groups carry data-sport on the .lg-hdr; toggle .hidden on each .lg-group.
  document.querySelectorAll('.lg-group').forEach(g => {
    const hdr = g.querySelector('.lg-hdr');
    const s = hdr ? hdr.dataset.sport : '';
    g.classList.toggle('hidden', sport !== 'all' && s !== sport);
  });
  // If we're viewing a hidden sport's board, switch to the first league of the
  // selected sport. SPORT_CFG keys ARE the sport name now (NBA, NCAAB, etc.).
  if(sport !== 'all' && activeLeague && !activeLeague.startsWith(sport)){
    const firstLeague = LEAGUES_LIST.find(l => l.sport === sport);
    if(firstLeague){
      activeLeague = firstLeague.name;
      document.getElementById('board-title').textContent = firstLeague.name;
      const sportKey = getActiveSportKey();
      const sc = SPORT_CFG.find(s => s.key === sportKey);
      if(sc && gamesCache[sc.key]) renderBoard();
      else if(sc) fetchAndRender(sc.key, true);
    }
  }
}

// ─── INIT ───────────────────────────────────────────
function init(){
  updateBalDisp();
  updateBetsBtn();
  renderSidebar();
  setMode('straight');
  setOnline(mockMode || !!apiKey);
  if(mockMode || apiKey){ fetchAndRender(getActiveSportKey()); startAuto(); }
  else { showBoardMsg('key'); }
}

if(document.readyState === 'loading'){
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}

// Persist any in-flight balance/bets on tab close (cheap insurance).
window.addEventListener('beforeunload', () => {
  localStorage.setItem('bs_bal', balance);
  localStorage.setItem('bs_bets', JSON.stringify(placedBets));
});

// ─── EXPOSE TO INLINE HANDLERS ──────────────────────
// index.html uses onclick="setMode('straight')" etc. With ES modules, top-level
// declarations are NOT global (unlike a classic <script>). We need to expose
// every function called from inline handlers on window.
const _expose = {
  setMode, onContinue, closeReview, confirmWagers,
  manualRefresh, filterSport, clearSelections,
  openParlayModal, closePM, updatePMCalc, confirmParlay,
  closeIF, confirmIfBet,
  closeTM, updateTMCalc, confirmTeaser, closeTeaserPayouts,
  openBets, closeBets, settleBet,
  openSettings, closeSettings, saveApiKey, saveBook, resetBalance, toggleMockMode,
};
Object.assign(window, _expose);
